# Arc testnet
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# USDC on Arc — native gas token AND ERC-20 interface at the same address (6 decimals via ERC-20)
# This is a fixed system contract address, the same on all Arc deployments.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Deployer wallet private key — used by bootstrap.ts to deploy contracts.
# Must hold native USDC on Arc testnet for gas. Fund from the Arc faucet.
# Generate with: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log('Key:    ',w.privateKey); console.log('Address:',w.address)"
DEPLOYER_PRIVATE_KEY=


# Circle Developer Platform
# Obtain from https://developers.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Circle Wallet Set ID (created once, reused for all wallets in this project)
CIRCLE_WALLET_SET_ID=

# OpenWeatherMap (free tier — 60 calls/min)
# Obtain from https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Treasury wallet (populated by bootstrap.ts — do not set manually)
TREASURY_ADDRESS=
TREASURY_WALLET_ID=

# Aggregator wallet (populated by bootstrap.ts)
AGGREGATOR_ADDRESS=
AGGREGATOR_WALLET_ID=

# Policyholder wallet (populated by bootstrap.ts)
POLICYHOLDER_ADDRESS=
POLICYHOLDER_WALLET_ID=

# Customer wallet (populated by bootstrap.ts)
CUSTOMER_ADDRESS=
CUSTOMER_WALLET_ID=

# Operator wallets (populated by bootstrap.ts)
OPERATOR1_ADDRESS=
OPERATOR1_WALLET_ID=
OPERATOR2_ADDRESS=
OPERATOR2_WALLET_ID=
OPERATOR3_ADDRESS=
OPERATOR3_WALLET_ID=
OPERATOR4_ADDRESS=
OPERATOR4_WALLET_ID=
OPERATOR5_ADDRESS=
OPERATOR5_WALLET_ID=

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_BACKEND_PORT=3010

# Aggregator service
AGGREGATOR_PORT=4000

# x402 facilitator — set to local aggregator so operators can use Arc
# Once aggregator is running, operators should have:
#   X402_FACILITATOR_URL=http://localhost:4000/facilitator
X402_FACILITATOR_URL=http://localhost:4000/facilitator

# Circle Gateway facilitator for nanopayments (Arc testnet)
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com/gateway

# Sensor operator ports (one per instance)
OPERATOR1_PORT=3001
OPERATOR2_PORT=3002
OPERATOR3_PORT=3003
OPERATOR4_PORT=3004
OPERATOR5_PORT=3005
